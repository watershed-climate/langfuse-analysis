# Option 1: Run ./scripts/get-secrets to populate .env from 1Password
# Option 2: Manually fill in values below

LANGFUSE_HOST="https://us.cloud.langfuse.com"

# Which project to target by default. Queries can be pointed at a different
# project by setting LANGFUSE_PROJECT on the command line, e.g.
#   LANGFUSE_PROJECT=reporting_answer uv run python -m queries.prompt_type
LANGFUSE_PROJECT="labs_agent"

# Add a {PREFIX}_PUBLIC_KEY and {PREFIX}_SECRET_KEY pair for each project
# you want to query. The prefix is LANGFUSE_{name.upper()}.
LANGFUSE_LABS_AGENT_PUBLIC_KEY=pk-lf-...
LANGFUSE_LABS_AGENT_SECRET_KEY=sk-lf-...
